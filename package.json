		"svelte-check": "^3.6.3",
		"svelte-preprocess": "^5.1.4",
		"tslib": "^2.6.2",
		"typescript": "^5.4.5"
	},
	"type": "module",
	"dependencies": {
		"@indaco/svelte-iconoir": "^7.7.0",
		"@sveltejs/adapter-static": "^3.0.1"
